# Default: no external LLM, use deterministic scripted fallback.
LLM_PROVIDER=scripted

# LM Studio / other OpenAI-compatible server example:
# LLM_PROVIDER=openai_compatible
# LLM_BASE_URL=http://your-llm-server:1234/v1
# LLM_API_KEY=lm-studio-or-your-reverse-proxy-key
# LLM_MODEL=your-loaded-model-id
